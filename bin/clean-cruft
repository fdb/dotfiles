#!/bin/bash
set -euo pipefail

# Recursively remove regenerable dependency/cache directories
# (.venv, __pycache__, node_modules, ...) from a folder.
# Useful before backups or cloud sync, which choke on file count.
#
# Usage: clean-cruft [-n] [-y] <folder>
#   -n   dry run: list what would be removed, delete nothing
#   -y   skip the confirmation prompt

# Directory names to remove. Edit to taste.
targets=(.venv venv __pycache__ node_modules .pytest_cache .mypy_cache)

dry_run=false
assume_yes=false

while getopts ":ny" opt; do
    case "$opt" in
        n) dry_run=true ;;
        y) assume_yes=true ;;
        *) echo "Usage: clean-cruft [-n] [-y] <folder>" >&2; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

if [[ $# -ne 1 ]]; then
    echo "Usage: clean-cruft [-n] [-y] <folder>" >&2
    exit 1
fi

root="$1"

# Safety: the target must exist and be a directory, not a file or symlink.
if [[ ! -d "$root" ]]; then
    echo "Error: '$root' is not a directory" >&2
    exit 1
fi
if [[ -L "$root" ]]; then
    echo "Error: '$root' is a symlink; refusing to follow" >&2
    exit 1
fi

# Build the find name filters: -name .venv -o -name __pycache__ -o ...
name_args=()
for t in "${targets[@]}"; do
    name_args+=(-name "$t" -o)
done
unset 'name_args[${#name_args[@]}-1]'  # drop trailing -o

# -prune so we don't descend into a matched dir (faster, no nested dupes).
found=()
while IFS= read -r -d '' dir; do
    found+=("$dir")
done < <(find "$root" -type d \( "${name_args[@]}" \) -prune -print0 2>/dev/null)

if [[ ${#found[@]} -eq 0 ]]; then
    echo "Nothing to clean under '$root'."
    exit 0
fi

echo "Found ${#found[@]} director$([[ ${#found[@]} -eq 1 ]] && echo y || echo ies) to remove:"
for dir in "${found[@]}"; do
    size=$(du -sh "$dir" 2>/dev/null | cut -f1)
    printf "  %-8s %s\n" "$size" "$dir"
done

if [[ "$dry_run" == true ]]; then
    echo "(dry run, nothing deleted)"
    exit 0
fi

if [[ "$assume_yes" != true ]]; then
    read -r -p "Delete these ${#found[@]} directories? [y/N] " reply
    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi
fi

for dir in "${found[@]}"; do
    # Re-check at delete time: still a real directory, not a symlink.
    if [[ -d "$dir" && ! -L "$dir" ]]; then
        rm -rf -- "$dir"
        echo "Removed $dir"
    else
        echo "Skipped $dir (no longer a directory)" >&2
    fi
done
